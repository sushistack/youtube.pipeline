# youtube.pipeline — API keys (secrets)
# Copy this file to ~/.youtube-pipeline/.env and fill in your keys.
# Never commit actual API keys to version control.

DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Non-secrets (cost caps, model IDs, paths) live in config.yaml — see the
# init command's sample config. Cost caps include `cost_cap_per_run` (NFR-C2
# backstop) and per-stage caps (cost_cap_research/write/image/tts/assemble).
