# youtube.pipeline — API keys (secrets)
# Copy this file to ./.env (project root, .gitignored) and fill in your keys.
# Never commit actual API keys to version control.

DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Non-secrets (cost caps, model IDs, paths) live in ./config.yaml — generated
# by `pipeline init` from domain.DefaultConfig and tracked in git so config
# changes flow through review. Cost caps include `cost_cap_per_run` (NFR-C2
# backstop) and per-stage caps (cost_cap_research/write/image/tts/assemble).
