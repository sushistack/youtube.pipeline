{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["scp_id", "title", "frozen_descriptor", "scenes", "shot_overrides", "metadata", "source_version"],
  "properties": {
    "scp_id": {"type": "string"},
    "title": {"type": "string"},
    "frozen_descriptor": {"type": "string"},
    "scenes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scene_num", "act_id", "narration", "estimated_tts_duration_s", "shot_count", "shots"],
        "properties": {
          "scene_num": {"type": "integer", "minimum": 1},
          "act_id": {"type": "string"},
          "narration": {"type": "string"},
          "estimated_tts_duration_s": {"type": "number", "minimum": 0},
          "shot_count": {"type": "integer", "minimum": 1, "maximum": 5},
          "shots": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["shot_index", "visual_descriptor", "estimated_duration_s", "transition"],
              "properties": {
                "shot_index": {"type": "integer", "minimum": 1},
                "visual_descriptor": {"type": "string"},
                "estimated_duration_s": {"type": "number", "minimum": 0},
                "transition": {"type": "string", "enum": ["ken_burns", "cross_dissolve", "hard_cut"]}
              }
            }
          }
        }
      }
    },
    "shot_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "shot_count": {"type": "integer", "minimum": 1, "maximum": 5},
          "transition": {"type": "string", "enum": ["ken_burns", "cross_dissolve", "hard_cut"]}
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visual_breakdown_model", "visual_breakdown_provider", "prompt_template", "shot_formula_version"],
      "properties": {
        "visual_breakdown_model": {"type": "string"},
        "visual_breakdown_provider": {"type": "string"},
        "prompt_template": {"type": "string"},
        "shot_formula_version": {"const": "tts-duration-v1"}
      }
    },
    "source_version": {"const": "v1-visual-breakdown"}
  }
}
