{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["checkpoint", "verdict", "overall_score", "rubric", "feedback", "scene_notes", "precheck", "critic_model", "critic_provider", "source_version"],
  "additionalProperties": false,
  "properties": {
    "checkpoint": { "const": "post_writer" },
    "verdict": { "enum": ["pass", "retry", "accept_with_notes"] },
    "retry_reason": { "type": "string", "minLength": 1 },
    "overall_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "rubric": {
      "type": "object",
      "required": ["hook", "fact_accuracy", "emotional_variation", "immersion"],
      "additionalProperties": false,
      "properties": {
        "hook": { "type": "integer", "minimum": 0, "maximum": 100 },
        "fact_accuracy": { "type": "integer", "minimum": 0, "maximum": 100 },
        "emotional_variation": { "type": "integer", "minimum": 0, "maximum": 100 },
        "immersion": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "feedback": { "type": "string", "minLength": 1 },
    "scene_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_num", "issue", "suggestion"],
        "additionalProperties": false,
        "properties": {
          "scene_num": { "type": "integer", "minimum": 1 },
          "issue": { "type": "string", "minLength": 1 },
          "suggestion": { "type": "string", "minLength": 1 }
        }
      }
    },
    "precheck": {
      "type": "object",
      "required": ["schema_valid", "forbidden_term_hits", "short_circuited"],
      "additionalProperties": false,
      "properties": {
        "schema_valid": { "type": "boolean" },
        "forbidden_term_hits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "short_circuited": { "type": "boolean" }
      }
    },
    "critic_model": { "type": "string", "minLength": 1 },
    "critic_provider": { "type": "string", "minLength": 1 },
    "source_version": { "const": "v1-critic-post-writer" }
  }
}
