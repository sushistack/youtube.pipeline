{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["scp_id", "title", "scenes", "metadata", "source_version"],
  "additionalProperties": false,
  "properties": {
    "scp_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "scenes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["scene_num", "act_id", "narration", "fact_tags", "mood", "entity_visible", "location", "characters_present", "color_palette", "atmosphere"],
        "additionalProperties": false,
        "properties": {
          "scene_num": { "type": "integer", "minimum": 1 },
          "act_id": { "type": "string", "minLength": 1 },
          "narration": { "type": "string", "minLength": 1 },
          "fact_tags": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "content"],
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string", "minLength": 1 },
                "content": { "type": "string", "minLength": 1 }
              }
            }
          },
          "mood": { "type": "string", "minLength": 1 },
          "entity_visible": { "type": "boolean" },
          "location": { "type": "string", "minLength": 1 },
          "characters_present": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "color_palette": { "type": "string", "minLength": 1 },
          "atmosphere": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["language", "scene_count", "writer_model", "writer_provider", "prompt_template", "format_guide_template", "forbidden_terms_version"],
      "additionalProperties": false,
      "properties": {
        "language": { "const": "ko" },
        "scene_count": { "type": "integer", "minimum": 4, "maximum": 32 },
        "writer_model": { "type": "string", "minLength": 1 },
        "writer_provider": { "type": "string", "minLength": 1 },
        "prompt_template": { "type": "string", "minLength": 1 },
        "format_guide_template": { "type": "string", "minLength": 1 },
        "forbidden_terms_version": { "type": "string", "minLength": 1 }
      }
    },
    "source_version": { "const": "v1-llm-writer" }
  }
}
